# Prevent directory listing
Options -Indexes

# Protect sensitive files globally
<FilesMatch "\.(json|md|env|log)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Redirect all requests to index.php if they don't exist
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . index.php [L]
